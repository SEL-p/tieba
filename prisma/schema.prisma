generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  phone         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          String    @default("ACHETEUR")
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  livreur       Livreur?
  orders        Order[]
  seller        Seller?
  cartItems     CartItem[]
  favorites     Favorite[]
  staffAccount  StaffAccount?
  sourcingRequests SourcingRequest[]
}

model Seller {
  id                 String    @id @default(cuid())
  userId             String    @unique
  businessName       String
  description        String?
  category           String?
  verified           Boolean   @default(false)
  location           String?
  rating             Float     @default(0)
  registrationNumber String?
  productTypes       String?
  deliveryType       String    @default("TIÉBA")
  subscriptionPlan   String    @default("STARTER")
  facebookUrl        String?
  instagramUrl       String?
  tiktokUrl          String?
  pixelId            String?
  facebookAccessToken String?
  tiktokAccessToken   String?
  instagramAccessToken String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  products           Product[]
  user               User           @relation(fields: [userId], references: [id])
  staffAccounts      StaffAccount[]
  liveStreams        LiveStream[]
}

model Livreur {
  id            String            @id @default(cuid())
  userId        String            @unique
  status        String            @default("INACTIF")
  vehicleType   String?           // MOTO, VELO, VOITURE
  vehiclePlate  String?           // Plaque d'immatriculation
  phone         String?           // Numéro WhatsApp direct
  zone          String?           // Zone d'activité (ex: Cocody, Marcory)
  rating        Float             @default(0)
  totalEarnings Float             @default(0)
  balance       Float             @default(0) // Somme non retirée
  isVerified    Boolean           @default(false)
  
  // Documents de vérification
  idCardUrl     String?
  licenseUrl    String?
  vehicleDocUrl String?

  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  missions      DeliveryMission[]
  payouts       Payout[]
  referralCode  String?           @unique
  referredById  String?
  challenges    Bonus[]
  user          User              @relation(fields: [userId], references: [id])
}

model Challenge {
  id            String   @id @default(cuid())
  title         String
  description   String
  targetCount   Int
  rewardAmount  Float
  active        Boolean  @default(true)
  startDate     DateTime @default(now())
  endDate       DateTime?
}

model Bonus {
  id            String   @id @default(cuid())
  livreurId     String
  type          String   // REFERRAL, CHALLENGE
  amount        Float
  status        String   @default("COMPLETED")
  description   String?
  createdAt     DateTime @default(now())
  livreur       Livreur  @relation(fields: [livreurId], references: [id])
}

model ChatMessage {
  id        String   @id @default(cuid())
  content   String
  senderId  String
  orderId   String
  createdAt DateTime @default(now())
  order     Order    @relation(fields: [orderId], references: [id])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  type      String   // ORDER, CHAT, PAYOUT, MISSION
  read      Boolean  @default(false)
  link      String?  // Optional link to redirect
  createdAt DateTime @default(now())
}

model Category {
  id       String    @id @default(cuid())
  name     String    @unique
  icon     String?
  image    String?
  color    String?
  products Product[]
}

model Product {
  id            String      @id @default(cuid())
  name          String
  description   String?
  price         Float
  originalPrice Float?
  image         String?
  categoryId    String
  sellerId      String
  rating        Float       @default(0)
  reviewsCount  Int         @default(0)
  salesCount    Int         @default(0)
  inStock       Boolean     @default(true)
  minOrder      String?
  location      String?
  badge         String?
  badgeType     String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  orderItems    OrderItem[]
  seller        Seller      @relation(fields: [sellerId], references: [id])
  category      Category    @relation(fields: [categoryId], references: [id])
  cartItems     CartItem[]
  favoritedBy   Favorite[]
  liveStreams   LiveStream[]
}

model Order {
  id            String           @id @default(cuid())
  userId        String
  status        String           @default("PENDING")
  subtotal      Float
  deliveryFee   Float            @default(0)
  platformFee   Float            @default(0)
  deliveryComm  Float            @default(0)
  total         Float
  paymentMethod String           @default("OM")
  paymentStatus String           @default("UNPAID")
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  mission       DeliveryMission?
  chatMessages  ChatMessage[]
  user          User             @relation(fields: [userId], references: [id])
  items         OrderItem[]
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  productId String
  quantity  Int
  price     Float
  product   Product @relation(fields: [productId], references: [id])
  order     Order   @relation(fields: [orderId], references: [id])
}

model DeliveryMission {
  id              String   @id @default(cuid())
  orderId         String   @unique
  livreurId       String?
  status          String   @default("WAITING") // WAITING, ACCEPTED, PICKING_UP, DELIVERING, COMPLETED, CANCELLED
  
  pickupAddress   String?
  pickupLat       Float?
  pickupLng       Float?
  pickupPhoto     String?    // Photo de preuve au ramassage
  
  deliveryAddress String
  deliveryLat     Float?
  deliveryLng     Float?
  deliveryPhoto   String?    // Photo de preuve à la livraison
  
  estimatedTime   Int?       // En minutes
  distanceKm      Float?
  
  completedAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  otpCode         String?    // Code à demander au client pour valider la livraison
  
  livreur         Livreur? @relation(fields: [livreurId], references: [id])
  order           Order    @relation(fields: [orderId], references: [id])
}

model Payout {
  id          String   @id @default(cuid())
  livreurId   String
  amount      Float
  method      String   // Orange Money, Wave, etc.
  phoneNumber String
  status      String   @default("PENDING") // PENDING, COMPLETED, REJECTED
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  livreur     Livreur  @relation(fields: [livreurId], references: [id])
}

model CartItem {
  id        String   @id @default(cuid())
  userId    String
  productId String
  quantity  Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id])
  product   Product  @relation(fields: [productId], references: [id])
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  productId String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
  product   Product  @relation(fields: [productId], references: [id])

  @@unique([userId, productId])
}

model PlatformConfig {
  id               String   @id @default("default")
  deliveryFeeBase  Float    @default(1500)
  deliveryFeeKm    Float    @default(100)
  livreurShare     Float    @default(0.80)
  contactEmail     String   @default("contact@tiebamarket.ci")
  contactPhone     String   @default("+225 07 00 00 00")
  facebookUrl      String?
  instagramUrl     String?
  seoTitle         String   @default("Tiéba Market")
  seoDescription   String   @default("Le meilleur marché en ligne")
  updatedAt        DateTime @updatedAt
}

model Banner {
  id        String   @id @default(cuid())
  imageUrl  String
  linkUrl   String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

model StaffAccount {
  id        String   @id @default(cuid())
  userId    String   @unique
  sellerId  String
  shopRole  String   @default("COMMERCIAL") // e.g. MANAGER, COMMERCIAL, SUPPORT
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id])
  seller    Seller   @relation(fields: [sellerId], references: [id])
}

model LiveStream {
  id             String    @id @default(cuid())
  sellerId       String
  title          String
  description    String?
  streamUrl      String?   // Lien d'intégration YouTube Live ou Twitch
  status         String    @default("SCHEDULED") // SCHEDULED, LIVE, ENDED
  scheduledFor   DateTime?
  featuredProdId String?   // Produit actuellement mis en avant
  viewersCount   Int       @default(0)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  seller         Seller    @relation(fields: [sellerId], references: [id])
  product        Product?  @relation(fields: [featuredProdId], references: [id])
}

model SourcingRequest {
  id            String   @id @default(cuid())
  userId        String
  productName   String
  category      String
  quantity      String
  budget        Float?
  details       String
  location      String
  deadline      DateTime
  status        String   @default("OPEN") // OPEN, CLOSED, COMPLETED
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  user          User     @relation(fields: [userId], references: [id])
}

model PromoCode {
  id              String    @id @default(cuid())
  code            String    @unique
  type            String    @default("PERCENTAGE") // PERCENTAGE or FIXED
  value           Float
  minOrderAmount  Float?
  maxDiscount     Float?
  usageLimit      Int?
  usageCount      Int       @default(0)
  expiresAt       DateTime?
  isActive        Boolean   @default(true)
  sellerId        String?   // Si null, c'est un code plateforme
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

